# Copy this file to .env and fill in your values for local development.
# Never commit .env — it is listed in .gitignore.
# In CI/CD these values are injected as GitHub Actions secrets.

# Required when sources.newsapi.enabled = true
NEWSAPI_KEY=your_newsapi_key_here

# Required when ai_summary.enabled = true and provider != "placeholder"
GROQ_API_KEY=your_groq_api_key_here

# Required when Teams publishing is enabled (feature 300)
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/...
